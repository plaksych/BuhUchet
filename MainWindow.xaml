<Window x:Class="BuhUchet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BuhUchet"
        Title="БухУчёт — Бухгалтерское приложение"
        Height="720" Width="1440"
        MinHeight="600" MinWidth="900"
        Background="#F0F2F5"
        Icon="pack://siteoforigin:,,,/Assets/appicon.png"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Основная цветовая схема -->
        <SolidColorBrush x:Key="PrimaryBrush"     Color="#1A3A5C"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#2E7DB5"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarnBrush"        Color="#F39C12"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush2"     Color="#D0D7DE"/>
        <SolidColorBrush x:Key="MutedBrush"       Color="#6C757D"/>
        <SolidColorBrush x:Key="SidebarBrush"     Color="#1A3A5C"/>

        <!-- Стиль кнопки навигации (sidebar) -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#A8C7E8"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"          Value="16,10"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E4D6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E7DB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Активная кнопка навигации -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#2E7DB5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Стиль обычной кнопки действия -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"       Value="#2E7DB5"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="14,7"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A6A9F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#B0C4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка опасного действия -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль TextBox -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush"      Value="#D0D7DE"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Background"       Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2E7DB5"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль Label формы -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#4A5568"/>
            <Setter Property="Margin"       Value="0,0,0,3"/>
        </Style>

        <!-- DataGrid строки -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#1A3A5C">
            <DockPanel>
                <!-- Логотип -->
                <Border DockPanel.Dock="Top" Padding="16,20,16,16"
                        BorderBrush="#2E4D6B" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📊 БухУчёт"
                                   Foreground="White" FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="v1.0 — учебная версия"
                                   Foreground="#6B9EC7" FontSize="10"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Навигация -->
                <Border Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="РАЗДЕЛЫ" Foreground="#4A6D8C"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="10,0,0,6"/>
                        <Button x:Name="BtnJournal"        Content="📋  Журнал операций"   Style="{StaticResource NavButtonActive}" Click="NavButton_Click" Tag="Journal"/>
                        <Button x:Name="BtnCounterparties" Content="🏢  Контрагенты"       Style="{StaticResource NavButton}"       Click="NavButton_Click" Tag="Counterparties"/>
                        <Button x:Name="BtnAccounts"       Content="📁  План счетов"        Style="{StaticResource NavButton}"       Click="NavButton_Click" Tag="Accounts"/>
                        <Button x:Name="BtnReports"        Content="📈  Отчёты (ОСВ)"       Style="{StaticResource NavButton}"       Click="NavButton_Click" Tag="Reports"/>
                    </StackPanel>
                </Border>

                <!-- Статус файла внизу -->
                <Border DockPanel.Dock="Bottom" Padding="14,10"
                        BorderBrush="#2E4D6B" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtFileName" Text="data.json"
                                   Foreground="#6B9EC7" FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtSavedAt" Text="Не сохранено"
                                   Foreground="#4A6D8C" FontSize="10"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── ЖУРНАЛ ОПЕРАЦИЙ ──────────────────────────────────────── -->
            <Grid x:Name="PanelJournal" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок + поиск -->
                <Border Grid.Row="0" Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Журнал хозяйственных операций"
                                       FontSize="18" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                            <TextBlock x:Name="TxtJournalCount" Text="0 записей"
                                       FontSize="12" Foreground="#6C757D" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="с" VerticalAlignment="Center" Margin="0,0,6,0"
                                       FontSize="11" Foreground="#6C757D"/>
                            <DatePicker x:Name="PickJournalFrom" Width="120" Margin="0,0,8,0"
                                        FontSize="12" SelectedDateChanged="JournalFilter_Changed"/>
                            <TextBlock Text="по" VerticalAlignment="Center" Margin="0,0,6,0"
                                       FontSize="11" Foreground="#6C757D"/>
                            <DatePicker x:Name="PickJournalTo" Width="120" Margin="0,0,8,0"
                                        FontSize="12" SelectedDateChanged="JournalFilter_Changed"/>
                            <Button x:Name="BtnJournalReset" Content="Сброс"
                                    Margin="0,0,10,0"
                                    Padding="10,7" FontSize="12"
                                    Click="BtnJournalReset_Click"
                                    Background="#EDF2F7" Foreground="#4A5568" BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E2E8F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBox x:Name="TxtSearch" Width="220" Margin="0,0,8,0"
                                     Style="{StaticResource FormTextBox}"
                                     TextChanged="TxtSearch_TextChanged">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="-34,0,14,0"
                                       Foreground="#6C757D" FontSize="14" IsHitTestVisible="False"/>
                            <Button Content="+ Добавить" Style="{StaticResource ActionButton}"
                                    Click="BtnAddEntry_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid x:Name="GridJournal" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          AlternationCount="2"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EDF2F7"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          Background="White"
                          RowHeight="34"
                          FontSize="12"
                          BorderThickness="0"
                          Margin="0"
                          SelectionChanged="GridJournal_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="#F8FAFC"/>
                            <Setter Property="Foreground"   Value="#4A5568"/>
                            <Setter Property="FontWeight"   Value="SemiBold"/>
                            <Setter Property="FontSize"     Value="11"/>
                            <Setter Property="Padding"      Value="10,8"/>
                            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№"           Binding="{Binding Id}"            Width="50"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Дата"        Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Дт"          Binding="{Binding DebitAccount}"  Width="60"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Кт"          Binding="{Binding CreditAccount}" Width="60"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Контрагент"  Binding="{Binding Counterparty}"  Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Сумма, руб." Binding="{Binding Amount, StringFormat=N2}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Содержание"  Binding="{Binding Description}"  Width="*"   IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Панель редактирования записи -->
                <Border x:Name="PanelEntryEdit" Grid.Row="2"
                        Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Счёт Дт" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Счёт Кт" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Контрагент (Tab — автодополнение)" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="ИНН" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Банк. счёт" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Сумма" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="Содержание" Style="{StaticResource FormLabel}"/>

                        <DatePicker x:Name="PickDate" Grid.Row="1" Grid.Column="0"
                                    Margin="0,0,8,0" VerticalContentAlignment="Center"
                                    FontSize="12"/>
                        <TextBox x:Name="TxtDebit"       Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource FormTextBox}" ToolTip="Счёт дебета (Tab — автодополнение)"/>
                        <TextBox x:Name="TxtCredit"      Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource FormTextBox}" ToolTip="Счёт кредита (Tab — автодополнение)"/>
                        <TextBox x:Name="TxtCounterparty" Grid.Row="1" Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <TextBox x:Name="TxtCounterpartyInn" Grid.Row="1" Grid.Column="4" Margin="0,0,8,0" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#F8FAFC"/>
                        <TextBox x:Name="TxtCounterpartyBank" Grid.Row="1" Grid.Column="5" Margin="0,0,8,0" Style="{StaticResource FormTextBox}" IsReadOnly="True" Background="#F8FAFC"/>
                        <TextBox x:Name="TxtAmount"      Grid.Row="1" Grid.Column="6" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <TextBox x:Name="TxtDescription" Grid.Row="1" Grid.Column="7" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>

                        <StackPanel Grid.Row="1" Grid.Column="8" Orientation="Horizontal">
                            <Button Content="✔ Сохранить" Style="{StaticResource ActionButton}"
                                    Margin="0,0,6,0" Click="BtnSaveEntry_Click"/>
                            <Button Content="✖" Style="{StaticResource DangerButton}"
                                    Width="40" Height="34" Padding="0" FontSize="14" Click="BtnDeleteEntry_Click"
                                    ToolTip="Удалить запись"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── КОНТРАГЕНТЫ ──────────────────────────────────────────── -->
            <Grid x:Name="PanelCounterparties" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Справочник контрагентов"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                        <Button Grid.Column="1" Content="+ Добавить контрагента"
                                Style="{StaticResource ActionButton}" Click="BtnAddCounterparty_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="GridCounterparties" Grid.Row="1"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternationCount="2" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EDF2F7" HeadersVisibility="Column"
                          SelectionMode="Single" Background="White" RowHeight="34"
                          FontSize="12" BorderThickness="0"
                          SelectionChanged="GridCounterparties_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="#F8FAFC"/>
                            <Setter Property="Foreground"   Value="#4A5568"/>
                            <Setter Property="FontWeight"   Value="SemiBold"/>
                            <Setter Property="FontSize"     Value="11"/>
                            <Setter Property="Padding"      Value="10,8"/>
                            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="ИНН"          Binding="{Binding Inn}"  Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Банк. счёт"   Binding="{Binding BankAccount}" Width="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Лицевой счёт" Binding="{Binding PersonalAccount}" Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Тип"          Binding="{Binding Type}" Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Форма контрагента -->
                <Border x:Name="PanelCpEdit" Grid.Row="2"
                        Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="ИНН" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Банк. счёт" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Лицевой счёт" Style="{StaticResource FormLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Тип" Style="{StaticResource FormLabel}"/>

                        <TextBox x:Name="TxtCpName" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <TextBox x:Name="TxtCpInn"  Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <TextBox x:Name="TxtCpBankAccount" Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <TextBox x:Name="TxtCpPersonalAccount" Grid.Row="1" Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource FormTextBox}"/>
                        <ComboBox x:Name="CbCpType" Grid.Row="1" Grid.Column="4" Margin="0,0,8,0"
                                  FontSize="12" Padding="6,5"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem>Поставщик</ComboBoxItem>
                            <ComboBoxItem>Покупатель</ComboBoxItem>
                            <ComboBoxItem>Прочее</ComboBoxItem>
                        </ComboBox>

                        <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal">
                            <Button Content="✔ Сохранить" Style="{StaticResource ActionButton}"
                                    Margin="0,0,6,0" Click="BtnSaveCp_Click"/>
                            <Button Content="✖" Style="{StaticResource DangerButton}"
                                    Width="40" Height="34" Padding="0" FontSize="14"
                                    Click="BtnDeleteCp_Click" ToolTip="Удалить"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── ПЛАН СЧЕТОВ ───────────────────────────────────────────── -->
            <Grid x:Name="PanelAccounts" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <TextBlock Text="План счетов бухгалтерского учёта"
                               FontSize="18" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                </Border>

                <DataGrid x:Name="GridAccounts" Grid.Row="1"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternationCount="2" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EDF2F7" HeadersVisibility="Column"
                          SelectionMode="Single" Background="White" RowHeight="34"
                          FontSize="12" BorderThickness="0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="#F8FAFC"/>
                            <Setter Property="Foreground"   Value="#4A5568"/>
                            <Setter Property="FontWeight"   Value="SemiBold"/>
                            <Setter Property="FontSize"     Value="11"/>
                            <Setter Property="Padding"      Value="10,8"/>
                            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код"         Binding="{Binding Code}" Width="70"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Тип"         Binding="{Binding Type}" Width="90"  IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="Актив">
                                            <Setter Property="Foreground" Value="#27AE60"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="Пассив">
                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ── ОТЧЁТЫ / ОСВ ─────────────────────────────────────────── -->
            <Grid x:Name="PanelReports" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <TextBlock Text="Оборотно-сальдовая ведомость"
                               FontSize="18" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                </Border>

                <!-- Параметры отчёта -->
                <Border Grid.Row="1" Background="#F8FAFC" Padding="20,12"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Период с:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="12" Foreground="#4A5568"/>
                        <DatePicker x:Name="PickOsvFrom" Width="130" Margin="0,0,16,0" FontSize="12"/>
                        <TextBlock Text="по:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="12" Foreground="#4A5568"/>
                        <DatePicker x:Name="PickOsvTo" Width="130" Margin="0,0,20,0" FontSize="12"/>
                        <Button Content="📊 Сформировать" Style="{StaticResource ActionButton}"
                                Click="BtnBuildOsv_Click"/>
                    </StackPanel>
                </Border>

                <!-- Таблица ОСВ -->
                <DataGrid x:Name="GridOsv" Grid.Row="2"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternationCount="2" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EDF2F7" HeadersVisibility="Column"
                          SelectionMode="Single" Background="White" RowHeight="34"
                          FontSize="12" BorderThickness="0" IsReadOnly="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"   Value="#EBF5FB"/>
                            <Setter Property="Foreground"   Value="#1A3A5C"/>
                            <Setter Property="FontWeight"   Value="SemiBold"/>
                            <Setter Property="FontSize"     Value="11"/>
                            <Setter Property="Padding"      Value="10,8"/>
                            <Setter Property="BorderBrush"  Value="#D6EAF8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Счёт"        Binding="{Binding Account}"                             Width="60"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding AccountName}"                        Width="200"/>
                        <DataGridTextColumn Header="Сальдо нач. Дт"   Binding="{Binding OpenDebit,   StringFormat=N2}"  Width="110"/>
                        <DataGridTextColumn Header="Сальдо нач. Кт"   Binding="{Binding OpenCredit,  StringFormat=N2}"  Width="110"/>
                        <DataGridTextColumn Header="Оборот Дт"   Binding="{Binding TurnDebit,  StringFormat=N2}"        Width="110"/>
                        <DataGridTextColumn Header="Оборот Кт"   Binding="{Binding TurnCredit, StringFormat=N2}"        Width="110"/>
                        <DataGridTextColumn Header="Сальдо кон. Дт"  Binding="{Binding CloseDebit,  StringFormat=N2}"   Width="110"/>
                        <DataGridTextColumn Header="Сальдо кон. Кт"  Binding="{Binding CloseCredit, StringFormat=N2}"   Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Итоги ОСВ -->
                <Border Grid.Row="3" Background="#EBF5FB" Padding="20,10"
                        BorderBrush="#D6EAF8" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TxtOsvTotals"
                               FontSize="12" FontWeight="SemiBold" Foreground="#1A3A5C"/>
                </Border>

                <!-- Экспорт отчёта -->
                <Border Grid.Row="4" Background="White" Padding="20,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnLoadOsv" Content="📂 Загрузить отчёт (JSON)" Style="{StaticResource ActionButton}"
                                Margin="0,0,8,0" Click="BtnLoadOsv_Click"/>
                        <Button x:Name="BtnExportOsv" Content="💾 Экспорт ОСВ (JSON)" Style="{StaticResource ActionButton}"
                                Click="BtnExportOsv_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Статусная строка (в отдельной строке, не перекрывает контент) -->
            <Border Grid.Row="1" Background="#1A3A5C"
                    Padding="16,5" Height="26">
                <TextBlock x:Name="TxtStatus" Text="Готово"
                           Foreground="#A8C7E8" FontSize="11"/>
            </Border>
        </Grid>
    </Grid>
</Window>
