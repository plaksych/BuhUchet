<Window x:Class="BuhUchet.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BuhUchet — Вход" Height="380" Width="360"
        Icon="/assets/appicon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PwdBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="MainBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Background" Value="#2D6CDF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2D6CDF"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="30,20">
        <!-- Заголовок -->
        <TextBlock x:Name="TitleText" Text="Вход в систему"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="#222" Margin="0,0,0,5"/>
        <TextBlock x:Name="SubtitleText" Text="Введите свои данные для входа"
                   FontSize="12" Foreground="#777" Margin="0,0,0,15"/>

        <!-- Логин -->
        <TextBlock Text="Имя пользователя" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="UsernameBox" Style="{StaticResource InputBox}"/>

        <!-- Пароль -->
        <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
        <PasswordBox x:Name="PasswordBox" Style="{StaticResource PwdBox}"/>

        <!-- Ошибка -->
        <TextBlock x:Name="ErrorText" Text="" Foreground="#D32F2F"
                   FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>

        <!-- Кнопка действия -->
        <Button x:Name="ActionButton" Content="Войти"
                Style="{StaticResource MainBtn}"
                Margin="0,16,0,8" Click="Action_Click"/>

        <!-- Переключатель режима -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock x:Name="SwitchLabel" Text="Нет аккаунта? "
                       FontSize="12" Foreground="#777" VerticalAlignment="Center"/>
            <Button x:Name="SwitchButton" Content="Зарегистрироваться"
                    Style="{StaticResource LinkBtn}" Click="Switch_Click"/>
        </StackPanel>

    </StackPanel>
</Window>